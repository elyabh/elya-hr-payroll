# SQL Server (docker-compose)
MSSQL_SA_PASSWORD=Your_password123
MSSQL_PORT=1433

# Redis (docker-compose)
REDIS_PORT=6379
REDIS_CONNECTION=localhost:6379

# API connection string (matches appsettings DefaultConnection)
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=ElyaHrPayroll;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False

# Frontend (copy to frontend/elya-web/.env)
VITE_API_BASE_URL=http://localhost:5080
